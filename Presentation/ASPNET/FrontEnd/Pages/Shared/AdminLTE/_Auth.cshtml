<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"]</title>

    <!-- Tabler CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/core@@latest/dist/css/tabler.min.css">

    @await RenderSectionAsync("styles", required: false)

    <style>
        [v-cloak] {
            display: none !important;
        }
    </style>

    @* vue *@
    <script src="~/lib/vue/vue.global.prod.js"></script>

    <script src="~/lib/axios/axios.min.js" defer></script>
    <script src="~/lib/sweetalert/sweetalert2v11.js" defer></script>
    <script src="~/lib/indotalent/storage-manager.js" defer></script>
    <script src="~/lib/indotalent/security-manager.js" defer></script>
    <script src="~/lib/indotalent/axios-manager.js" defer></script>
</head>

<body class="d-flex flex-column antialiased">
    <div class="page page-center">
        <div class="container container-tight py-4">
            <div class="text-center mb-4">
                <a asp-area="" asp-page="/Index" class="navbar-brand navbar-brand-autodark d-inline-block">
                    <span class="fw-bold fs-2">DASHBOARD.</span>
                </a>
            </div>
            <div class="card card-md shadow-sm">
                @RenderBody()
            </div>
        </div>
    </div>

    <!-- Tabler JS (includes Bootstrap 5) -->
    <script src="https://cdn.jsdelivr.net/npm/@@tabler/core@@latest/dist/js/tabler.min.js"></script>

    @await RenderSectionAsync("scripts", required: false)
</body>
</html>
